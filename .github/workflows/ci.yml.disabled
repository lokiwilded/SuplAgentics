name: CI

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  test-mcp:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: MCP
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
      - name: Install dependencies
        run: npm ci || npm install
      - name: Syntax check
        run: |
          node --check src/index.js
          node --check src/tools/rag-tools.js
          node --check src/tools/cache-tools.js
          node --check src/tools/import-tools.js
      - name: Run tests
        run: node --test test/*.test.js

  validate-agents:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
      - name: Validate agent frontmatter
        run: node MCP/src/tools/validate-agents.js OC/

  lint-sync-self:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
      - name: Syntax check sync-self.mjs
        run: node --check sync-self.mjs
      - name: Syntax check start.mjs
        run: node --check start.mjs
